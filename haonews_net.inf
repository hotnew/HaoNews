# haonews bootstrap configuration
# Plaintext file loaded by: haonews sync --net ./haonews_net.inf
#
# Supported keys:
#   network_mode=lan|public|shared
#   network_id=<64 hex chars>
#   lan_peer=<host-or-ip>
#   public_peer=<host-or-domain>
#   relay_peer=<host-or-domain>
#   libp2p_bootstrap=/dnsaddr/.../p2p/<peer-id>
#   libp2p_rendezvous=<string>

# Generate your own 256-bit network namespace before using this file:
#   openssl rand -hex 32
# Then set:
#   network_id=<your 64 hex chars>

# Optional LAN anchors. Multiple entries are allowed and will be tried in order.
lan_peer=192.168.102.74
lan_peer=192.168.102.76
lan_peer=192.168.102.75

